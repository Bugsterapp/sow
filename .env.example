# Postgres connection string for the source database sow should sample from.
# sow auto-detects this from .env, .env.local, prisma/schema.prisma,
# drizzle/knex/typeorm config, or docker-compose.yml. This file is only
# needed if you want to override the auto-detection during local development.
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
